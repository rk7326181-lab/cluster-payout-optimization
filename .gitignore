Awb_with_polygon_mapping.csv

# data/ default: ignore everything inside…
data/*
# …but ALLOW the small map snapshot files so the deployed app survives
# Streamlit Cloud reboots (container disk is wiped, but the git checkout
# brings these back). awb_cache/ + hexbin_cache.json stay ignored (huge).
!data/cache_manifest.json
!data/clustering_live_*.csv
!data/hub_Lat_Long*.csv
!data/kepler_gl_final_main_*_csv.csv
!data/live_clusters_cache.json
data/awb_cache/
data/awb_cache/**
hexbin_cache.json

