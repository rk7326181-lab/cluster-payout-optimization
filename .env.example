# Environment Configuration Template
# Copy this file to .env and fill in your values

# BigQuery Configuration (Optional - only needed for live data)
BIGQUERY_PROJECT_ID=your-project-id-here
BIGQUERY_CREDENTIALS_PATH=config/credentials.json

# Default Settings
DEFAULT_YEAR=2026
DEFAULT_MONTH=3

# Application Settings
APP_TITLE=Hub Cluster Cost Optimization Dashboard
APP_ICON=🗺️
PAGE_LAYOUT=wide

# Data Refresh Interval (in seconds)
CACHE_TTL=3600

# Map Configuration
DEFAULT_MAP_CENTER_LAT=20.5937
DEFAULT_MAP_CENTER_LON=78.9629
DEFAULT_ZOOM=5

# Feature Flags
ENABLE_BIGQUERY=false
ENABLE_EXPORTS=true
ENABLE_COMPARISONS=true

# Debug Mode
DEBUG=false
VERBOSE_LOGGING=false
